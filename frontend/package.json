{
	"name": "uni-frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"generate:contract": "node scripts/generate-schemas.js",
		"build": "node scripts/generate-schemas.js && vite build",
		"watch": "vite build --watch --mode development",
		"preview": "vite preview",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"docs": "typedoc",
		"pdf": "mkdir -p docs/build && cat docs/markdown/**/*.md > docs/build/_tsdoc.md && node docs/md2pdf-pixel.cjs docs/build/_tsdoc.md frontend-manual.pdf"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"@vitest/ui": "^2.1.9",
		"jsdom": "^25.0.1",
		"md-to-pdf": "^5.2.5",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.4",
		"sveltedoc-parser": "^4.2.1",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.12.0",
		"typescript-svelte-plugin": "^0.3.52",
		"vite": "^6.3.0",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"@dnd-kit-svelte/svelte": "^0.1.6",
		"@dnd-kit/svelte": "^0.4.0",
		"@tailwindcss/vite": "^4.3.1",
		"esbuild": "^0.28.0",
		"svelte-dnd-action": "^0.9.69",
		"tailwindcss": "^4.3.1",
		"zod": "^4.4.3"
	}
}
