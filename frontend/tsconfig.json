{
  "compilerOptions": {
    "target": "ES2015",
    "module": "commonjs",
    "strict": true,
    "types": ["svelte", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "$lib/*": ["src/lib/*"],
      "$stores/*": ["src/lib/stores/*"],
      "$utils/*": ["src/lib/utils/*"],
      "$common/*": ["src/lib/components/common/*"]
    }
  }
}
