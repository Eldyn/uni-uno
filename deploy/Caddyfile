# Caddy reverse proxy for the UNI backend on OCI.
#
# {$DOMAIN} is substituted from the container environment (set in
# docker-compose.oci.yml from the host .env). Caddy automatically provisions and
# renews a Let's Encrypt certificate for it over HTTP-01, so ports 80 and 443
# must be reachable (OCI Security List + host firewall).
#
# reverse_proxy transparently upgrades WebSocket connections, so the frontend's
# wss:// traffic is proxied to the backend's ws:// on :3000 with no extra config.

{$DOMAIN} {
	encode zstd gzip
	reverse_proxy uni:3000
}
