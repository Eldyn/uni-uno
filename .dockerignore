CMakeUserPresets.json
ConanPresets.json

# Local databases
*.db
*.sqlite
db_data/

# Secrets & certificates (injected at runtime, never baked into the image)
.env
certs/
*.pem
*.crt
*.key
*.p12
*.pfx
*.csr

# VCS & docs
.git/
.gitignore
docs/
frontend/docs/

# Editor
.vs/
.vscode/
.clangd
